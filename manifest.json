{
  "manifest_version": 3,
  "name": "Sea Turtle",
  "version": "1.5.0",
  "description": "AI powered super SeaTalk.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.search.brave.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://seatalkweb.com/*"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "action": {
    "default_title": "Image Search"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "side-panel.html"
  }
}